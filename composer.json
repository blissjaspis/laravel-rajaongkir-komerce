{
    "name": "blissjaspis/laravel-rajaongkir-komerce",
    "description": "Laravel Rajaongkir From Komerce",
    "type": "library",
    "version": "2.0.0",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.9",
        "illuminate/console": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^10.0 || ^11.0",
        "phpunit/phpunit": "^12.0 || ^13.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "BlissJaspis\\RajaOngkir\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Workbench\\App\\": "workbench/app/",
            "BlissJaspis\\RajaOngkir\\Tests\\": "tests/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "analyze": "vendor/bin/phpstan analyse",
        "test": "@php vendor/bin/phpunit",
        "format": "vendor/bin/pint",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "lint": [
            "@php vendor/bin/pint --ansi"
        ]
    },
    "authors": [
        {
            "name": "Bliss Jaspis",
            "email": "jaspis_zzt@ymail.com"
        }
    ],
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "BlissJaspis\\RajaOngkir\\Providers\\RajaOngkirServiceProvider"
            ],
            "aliases": {
                "RajaOngkir": "BlissJaspis\\RajaOngkir\\Facades\\RajaOngkir"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}